const arr1 = [1, 2, 3];
const arr2 = [1, 2, 3];

let flag = true;

if (arr1.length !== arr2.length) {
    flag = false;
} else {
    for (let i = 0; i < arr1.length; i++) {
        if (arr1[i] !== arr2[i]) {
            flag = false;
            break;
        }
    }
}

if (flag) {
    console.log("Arrays are equal");
} else {
    console.log("Arrays are not equal");
}